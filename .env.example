# Application Configuration
APP_NAME=go-core
APP_ENV=development
APP_PORT=3000
APP_VERSION=1.0.0
APP_DEBUG=true
APP_ERROR_DOCS_URL=https://your-domain.com/errors/
APP_FRONTEND_URL=http://localhost:3000
APP_BODY_LIMIT=4194304
APP_PROXY_HEADER=X-Forwarded-For          # Real client IP header (CF-Connecting-IP for Cloudflare, X-Real-IP for nginx)

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DB_NAME=go_core_dev
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_SSL_MODE=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m
DATABASE_CONN_MAX_IDLE_TIME=5m
DATABASE_SLOW_QUERY_THRESHOLD=200ms

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_CONN_MAX_IDLE_TIME=5m
REDIS_CONN_MAX_LIFETIME=30m
REDIS_CB_FAILURE_THRESHOLD=5
REDIS_CB_RESET_TIMEOUT=30s

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=go-core-exchange
RABBITMQ_QUEUE_PREFIX=go-core
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_PROCESSED_MESSAGE_RETENTION=24h
RABBITMQ_OUTBOX_BATCH_SIZE=10
RABBITMQ_OUTBOX_MAX_RETRY=5

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=go-core

# Email Configuration (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@gocore.local
SMTP_FROM_NAME=Go-Core

# Casbin Authorization
CASBIN_MODEL_PATH=./configs/casbin_model.conf
CASBIN_POLICY_PATH=./configs/casbin_policy.csv

# OpenTelemetry Configuration
OTEL_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=go-core
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_INSECURE=true
OTEL_SAMPLE_RATE=1.0

# Tracing Configuration
TRACING_ENABLED=false
TRACING_EXPORTER=jaeger
TRACING_JAEGER_ENDPOINT=http://localhost:14268/api/traces
TRACING_OTLP_ENDPOINT=localhost:4317
TRACING_SERVICE_NAME=go-core

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
CORS_ALLOW_CREDENTIALS=true

# gRPC Configuration
GRPC_PORT=50051
GRPC_REFLECTION_ENABLED=true
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout

# File Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE=10485760

# S3/MinIO Storage (used when STORAGE_TYPE=s3)
STORAGE_S3_ENDPOINT=minio:9000
STORAGE_S3_BUCKET=go-core
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
STORAGE_S3_USE_SSL=false
STORAGE_S3_PRESIGN_TTL=15m
# Public endpoint for presigned URLs (use externally reachable address)
STORAGE_S3_PUBLIC_ENDPOINT=localhost:9000

# Security
SECURITY_BCRYPT_COST=12
SECURITY_API_KEY_HEADER=X-API-Key
SECURITY_ENCRYPTION_KEY=change-me-in-production-this-is-minimum-32-chars
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_ACCOUNT_LOCK_DURATION=15m

# FCM Push Notification
FCM_ENABLED=false
FCM_CREDENTIALS_FILE=path/to/firebase-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# SMS
SMS_ENABLED=false
SMS_PROVIDER=twilio

# Captcha Verification (turnstile or recaptcha)
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SITE_KEY=your-captcha-site-key
CAPTCHA_SECRET_KEY=your-captcha-secret-key
CAPTCHA_TIMEOUT=5s

# Webhook
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=your-webhook-signing-secret
WEBHOOK_TIMEOUT=10s
WEBHOOK_MAX_RETRIES=3

# SSE (Server-Sent Events)
SSE_ENABLED=true
SSE_ENABLE_REDIS=false
SSE_ENABLE_METRICS=false

# Notification
NOTIFICATION_MAX_WORKERS=50
NOTIFICATION_USE_RABBITMQ=false
NOTIFICATION_QUEUE_NAME=notifications.process
NOTIFICATION_PENDING_INTERVAL=60s
NOTIFICATION_RETRY_INTERVAL=120s

# Blog
BLOG_POSTS_PER_PAGE=20
BLOG_VIEW_COOLDOWN=30m
BLOG_MAX_MEDIA_SIZE=10485760
BLOG_SITE_URL=http://localhost:3000
BLOG_AUTO_APPROVE_COMMENTS=false
BLOG_FEED_ITEM_LIMIT=50
BLOG_READ_TIME_WPM=200
BLOG_TRENDING_WEIGHT_VIEW=1
BLOG_TRENDING_WEIGHT_LIKE=3
BLOG_TRENDING_WEIGHT_COMMENT=5
BLOG_TRENDING_WEIGHT_SHARE=2

# Docker Services (only used by docker-compose)
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
